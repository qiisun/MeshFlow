#!/bin/bash
# ============================================================
# TACC Lonestar6 SLURM batch script
# Generated by submit_ls6.py
# ============================================================

#SBATCH --job-name=bash
#SBATCH -p h100
#SBATCH -N 1
#SBATCH -t 12:00:00
#SBATCH -o /work2/11035/georgenakayama/ls6/MeshFlow2/bash_%j.out
#SBATCH -e /work2/11035/georgenakayama/ls6/MeshFlow2/bash_%j.err
#  (memory not set — using node default; add --mem=Xg if needed)

# ----------------------------------------------------------
# Print job metadata
# ----------------------------------------------------------
echo "Job ID        : $SLURM_JOB_ID"
echo "Job name      : $SLURM_JOB_NAME"
echo "Partition     : $SLURM_JOB_PARTITION"
echo "Nodes         : $SLURM_JOB_NUM_NODES"
echo "Tasks/node    : $SLURM_NTASKS_PER_NODE"
echo "CPUs/task     : $SLURM_CPUS_PER_TASK"
echo "Node list     : $SLURM_JOB_NODELIST"
echo "Submit dir    : $SLURM_SUBMIT_DIR"
date

# ----------------------------------------------------------
# Activate conda environment: meshflow
# ----------------------------------------------------------
source ~/.bashrc
source /work/11035/georgenakayama/ls6/miniconda3/bin/activate
conda activate meshflow

echo "Python        : $(which python)"
echo "Conda env     : $CONDA_DEFAULT_ENV"

# ----------------------------------------------------------
# Change to submission directory
# ----------------------------------------------------------
cd "$SLURM_SUBMIT_DIR" || exit 1

# ----------------------------------------------------------
# Run
# ----------------------------------------------------------
bash tools/run_train.sh configs/overfit/base-500m.yaml

echo "Job finished at $(date)"
